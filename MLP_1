lims = [min(yv_test.min(), yv_pred.min()), max(yv_test.max(), yv_pred.max())]
ax.plot(lims, lims, "r--", linewidth=1)
ax.set_xlabel("True Velocity Magnitude (m/s)")
ax.set_ylabel("Predicted Velocity Magnitude (m/s)")
ax.set_title("Velocity: Predicted vs True")
ax.grid(True, alpha=0.3)

# 8.3 压力模型训练Loss曲线
ax = axes[1, 0]
ax.plot(range(1, len(loss_history_p)+1), loss_history_p, 'b-', linewidth=1.5)
ax.set_xlabel("Epoch")
ax.set_ylabel("Loss (MSE)")
ax.set_title("Pressure Model Training Loss")
ax.set_yscale('log')  # 使用对数坐标更清晰
ax.grid(True, alpha=0.3)

# 8.4 速度模型训练Loss曲线
ax = axes[1, 1]
ax.plot(range(1, len(loss_history_v)+1), loss_history_v, 'orange', linewidth=1.5)
ax.set_xlabel("Epoch")
ax.set_ylabel("Loss (MSE)")
ax.set_title("Velocity Model Training Loss")
